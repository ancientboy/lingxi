# ========================================
# 灵犀云环境变量配置模板
# ========================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ========================================
# 必需配置（缺少将无法启动）
# ========================================

# 用户服务器 SSH 密码
USER_SERVER_PASSWORD=Lingxi@2026!

# 智谱 AI API Key
ZHIPU_API_KEY=your_zhipu_api_key_here

# 阿里云 DashScope API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ========================================
# 服务配置
# ========================================

# 服务器端口
PORT=3000

# 服务器 IP（公网）
SERVER_IP=your_server_ip

# JWT 密钥（可选，不填自动生成）
JWT_SECRET=

# 管理员密钥
ADMIN_KEY=lingxi-admin-2026

# ========================================
# OpenClaw 配置
# ========================================

# OpenClaw Gateway 地址
OPENCLAW_URL=http://localhost:18789

# OpenClaw Token
OPENCLAW_TOKEN=

# OpenClaw Session
OPENCLAW_SESSION=c308f1f0

# OpenClaw 端口
OPENCLAW_PORT=18789

# Docker 镜像
OPENCLAW_IMAGE=crpi-bcyqkynua4upy5gp.cn-hangzhou.personal.cr.aliyuncs.com/lingxi-cloud2026/lingxi-cloud:latest

# ========================================
# 阿里云配置（一键部署需要）
# ========================================

# 阿里云 AccessKey
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# 地域和可用区
ALIYUN_REGION=cn-hangzhou
ALIYUN_ZONE=cn-hangzhou-h

# VPC 配置（需要预先创建）
ALIYUN_VPC_ID=
ALIYUN_VSWITCH_ID=
ALIYUN_SECURITY_GROUP_ID=

# 实例配置
ALIYUN_INSTANCE_TYPE=ecs.g6.large
ALIYUN_DISK_SIZE=40
ALIYUN_BANDWIDTH=5

# ========================================
# 运行模式
# ========================================

# MVP 模式（共享实例）
MVP_MODE=false

# AI 代理服务器地址（用于 deploy.js 生成用户配置）（支持多个，逗号分隔，自动故障转移）
AI_PROXY_URLS=http://120.55.192.144:3000

# 后端轻代理地址（逗号分隔，按优先级排序）
# AI_BACKEND_PROXIES=http://localhost:3001,http://8.219.243.199:3001
